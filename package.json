{
  "name": "koko-contextos-agents",
  "version": "1.1.0",
  "description": "Install a .agents folder into your project to teach AI assistants best practices: UI/UX, architecture, security, and engineering workflow skills.",
  "bin": {
    "koko-contextos-agents": "./bin/index.js"
  },
  "files": [
    "bin",
    "registry.json",
    "registry.schema.json",
    ".agents/AGENTS.md",
    ".agents/skills.json",
    ".agents/ctx.js",
    ".agents/validate.js",
    ".agents/plugins.js",
    ".agents/adapters",
    ".agents/core",
    ".agents/generated",
    "benchmarks/gemini-issues.js"
  ],
  "scripts": {
    "build": "node .agents/ctx.js export all",
    "export": "node .agents/ctx.js export gemini",
    "validate": "node .agents/ctx.js validate",
    "benchmark": "node benchmarks/gemini-issues.js",
    "lint:md": "markdownlint README.md CONTRIBUTING.md '.agents/core/skills/**/*.md' --ignore '.agents/generated/**' --config .markdownlint.json",
    "test": "node --test --test-concurrency=1 tests/install.test.js tests/export.test.js tests/skills.test.js tests/validate.test.js tests/plugins.test.js tests/benchmark.test.js",
    "prepublishOnly": "npm run validate && npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "contextos",
    "ai-agents",
    "claude",
    "gemini",
    "cursor",
    "llm",
    "prompt-engineering",
    "skills",
    "coding-assistant"
  ],
  "author": "koko-o",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kok-o/koko-contextos-agents.git"
  },
  "homepage": "https://github.com/kok-o/koko-contextos-agents#readme",
  "bugs": {
    "url": "https://github.com/kok-o/koko-contextos-agents/issues"
  },
  "engines": {
    "node": ">=16.7.0"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.49.0"
  },
  "dependencies": {
    "inquirer": "^8.2.7"
  }
}
